# Google Gemini (primary model for meal/workout plan generation + translation)
# Model: gemini-2.5-flash-lite — used by @ai-sdk/google (reads this key automatically)
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek (fallback model for plan generation if Gemini fails)
# Used by @ai-sdk/deepseek (reads this key automatically)
DEEPSEEK_API_KEY=

# OpenRouter (OCR + RAG embeddings)
# Models: qwen/qwen3-vl-8b-instruct (OCR), openai/text-embedding-3-small (RAG)
OPENROUTER_API_KEY=

# Resend (transactional emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FitFast <noreply@fitfast.app>

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@fitfast.app

# Client app URL (used in emails for links back to the app)
CLIENT_APP_URL=https://app.fitfast.app

# Marketing site URL (used for CORS in HTTP endpoints)
MARKETING_SITE_URL=

# Seed data (only needed for development)
SEED_USER_PASSWORD=
